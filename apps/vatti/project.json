{
  "name": "vatti",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/vatti/src",
  "i18n": {
    "sourceLocale": "en-IN"
  },
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": [
        "prebuild-version",
        "prebuild-sentry",
        "^build"
      ],
      "executor": "@angular-devkit/build-angular:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/vatti",
        "index": "apps/vatti/src/index.html",
        "browser": "apps/vatti/src/main.ts",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/vatti/tsconfig.app.json",
        "inlineStyleLanguage": "css",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/vatti/public"
          }
        ],
        "styles": [
          "apps/vatti/src/styles.css"
        ],
        "scripts": [
          "node_modules/flowbite-datepicker/dist/js/datepicker-full.min.js"
        ]
      },
      "configurations": {
        "production": {
          "sourceMap": {
            "scripts": true,
            "hidden": true,
            "vendor": false
          },
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1mb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "statsJson": true,
          "serviceWorker": "apps/vatti/ngsw-config.json"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "prebuild-version": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [
        "{projectRoot}/src/generated/version.ts"
      ],
      "inputs": [
        "{projectRoot}/version"
      ],
      "options": {
        "command": "node tools/scripts/generate-version.mjs {projectName}"
      }
    },
    "prebuild-sentry": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [
        "{projectRoot}/src/generated/sentry-config.ts"
      ],
      "inputs": [
        "{workspaceRoot}/.env"
      ],
      "options": {
        "command": "node tools/scripts/generate-sentry-env.mjs {projectName}"
      }
    },
    "serve": {
      "dependsOn": [
        "prebuild-version",
        "prebuild-sentry"
      ],
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "port": 4300
      },
      "configurations": {
        "production": {
          "buildTarget": "vatti:build:production"
        },
        "development": {
          "buildTarget": "vatti:build:development"
        }
      },
      "defaultConfiguration": "development",
      "continuous": true
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "vatti:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "dependsOn": [
        "prebuild-version",
        "prebuild-sentry"
      ],
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}",
        "{workspaceRoot}/test-results/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/vatti/jest.config.ts",
        "tsConfig": "apps/vatti/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "vatti:build",
        "port": 4300,
        "staticFilePath": "dist/apps/vatti/browser",
        "spa": true
      }
    }
  }
}
